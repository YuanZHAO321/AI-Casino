{
  "name": "ai-casino",
  "version": "1.0.1",
  "description": "AI 陪玩赌场 — 拟真赌场桌面应用，AI 对手与陪玩（第一个游戏：21点）",
  "main": "out/main/index.js",
  "author": "zhaoyuan",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "dist:mac": "electron-vite build && electron-builder --mac --universal",
    "dist:win": "electron-vite build && electron-builder --win --x64",
    "dist:all": "electron-vite build && electron-builder --mac --universal --win --x64"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sherpa-onnx-darwin-arm64": "^1.13.2",
    "sherpa-onnx-node": "^1.13.2",
    "sherpa-onnx-win-x64": "^1.13.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.zhaoyuan.aicasino",
    "productName": "AI Casino",
    "directories": {
      "output": "release",
      "buildResources": "buildResources"
    },
    "files": [
      "out/**"
    ],
    "asarUnpack": [
      "out/main/ttsWorker.js",
      "node_modules/sherpa-onnx-node/**",
      "node_modules/sherpa-onnx-darwin-arm64/**",
      "node_modules/sherpa-onnx-darwin-x64/**",
      "node_modules/sherpa-onnx-win-x64/**"
    ],
    "mac": {
      "category": "public.app-category.card-games",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
